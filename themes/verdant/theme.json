{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "layout": { "contentSize": "640px", "wideSize": "1152px" },
    "color": {
      "palette": [
        { "slug": "ink", "color": "#1f3527", "name": "Ink" },
        { "slug": "soft", "color": "#46604f", "name": "Soft" },
        { "slug": "accent", "color": "#5f9265", "name": "Sage" },
        { "slug": "accent-deep", "color": "#2c5639", "name": "Forest" },
        { "slug": "accent-soft", "color": "#e4efdd", "name": "Mist" },
        { "slug": "paper", "color": "#f3f6ef", "name": "Paper" },
        { "slug": "surface", "color": "#ffffff", "name": "Surface" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"Iowan Old Style\", \"Palatino Linotype\", Palatino, Georgia, serif",
          "slug": "serif",
          "name": "Serif"
        },
        {
          "fontFamily": "\"Avenir Next\", \"Segoe UI\", system-ui, -apple-system, Roboto, sans-serif",
          "slug": "sans",
          "name": "Sans"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.9rem", "name": "Small" },
        { "slug": "medium", "size": "1.08rem", "name": "Medium" },
        { "slug": "large", "size": "1.6rem", "name": "Large" },
        { "slug": "x-large", "size": "2.35rem", "name": "Extra large" }
      ]
    }
  },
  "styles": {
    "color": { "background": "#f3f6ef", "text": "#1f3527" },
    "elements": {
      "link": { "color": { "text": "#2c5639" } }
    }
  }
}
