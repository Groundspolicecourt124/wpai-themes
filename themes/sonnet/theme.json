{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "layout": { "contentSize": "608px", "wideSize": "832px" },
    "color": {
      "palette": [
        { "slug": "ink", "color": "#e8e3d8", "name": "Ink" },
        { "slug": "soft", "color": "#b3ad9f", "name": "Soft" },
        { "slug": "faint", "color": "#7c7768", "name": "Faint" },
        { "slug": "accent", "color": "#caa15a", "name": "Accent" },
        { "slug": "charcoal", "color": "#15171c", "name": "Charcoal" },
        { "slug": "surface", "color": "#1b1e25", "name": "Surface" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"Iowan Old Style\", \"Palatino Linotype\", Palatino, Georgia, serif",
          "slug": "serif",
          "name": "Serif"
        },
        {
          "fontFamily": "ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif",
          "slug": "sans",
          "name": "Sans"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.833rem", "name": "Small" },
        { "slug": "medium", "size": "1.18rem", "name": "Medium" },
        { "slug": "large", "size": "1.48rem", "name": "Large" },
        { "slug": "x-large", "size": "2.31rem", "name": "Extra large" }
      ]
    }
  },
  "styles": {
    "color": { "background": "#15171c", "text": "#e8e3d8" },
    "elements": {
      "link": { "color": { "text": "#caa15a" } }
    }
  }
}
