{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": { "contentSize": "40rem", "wideSize": "54rem" },
    "color": {
      "palette": [
        { "slug": "ink", "color": "#ece7db", "name": "Ink" },
        { "slug": "ink-soft", "color": "#b6b0a1", "name": "Soft ink" },
        { "slug": "faint", "color": "#928c7d", "name": "Faint" },
        { "slug": "accent", "color": "#cba35d", "name": "Gold" },
        { "slug": "accent-hi", "color": "#e3c184", "name": "Gold light" },
        { "slug": "charcoal", "color": "#14161b", "name": "Charcoal" },
        { "slug": "charcoal-deep", "color": "#101217", "name": "Deep charcoal" },
        { "slug": "surface", "color": "#1a1d24", "name": "Surface" }
      ],
      "custom": false,
      "customGradient": false,
      "defaultPalette": false,
      "defaultGradients": false
    },
    "typography": {
      "customFontSize": false,
      "fontFamilies": [
        {
          "fontFamily": "\"Iowan Old Style\", \"Palatino Linotype\", Palatino, \"Sorts Mill Goudy\", \"Book Antiqua\", Georgia, Cambria, \"Times New Roman\", serif",
          "slug": "serif",
          "name": "Serif"
        },
        {
          "fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
          "slug": "sans",
          "name": "Sans"
        },
        {
          "fontFamily": "ui-monospace, \"SFMono-Regular\", \"Cascadia Code\", \"Roboto Mono\", Menlo, Consolas, monospace",
          "slug": "mono",
          "name": "Mono"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.8rem", "name": "Small" },
        { "slug": "medium", "size": "1.1875rem", "name": "Medium" },
        { "slug": "large", "size": "1.48rem", "name": "Large" },
        { "slug": "x-large", "size": "1.85rem", "name": "Extra large" },
        { "slug": "xx-large", "size": "2.32rem", "name": "Huge" }
      ]
    },
    "spacing": {
      "units": [ "px", "em", "rem", "vh", "vw", "%" ]
    }
  },
  "styles": {
    "color": { "background": "#14161b", "text": "#ece7db" },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--serif)",
      "fontSize": "1.1875rem",
      "lineHeight": "1.78"
    },
    "elements": {
      "link": {
        "color": { "text": "#cba35d" },
        ":hover": { "color": { "text": "#e3c184" } }
      },
      "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } },
      "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } },
      "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--serif)" } }
    }
  }
}
