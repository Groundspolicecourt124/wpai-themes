{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": { "contentSize": "704px", "wideSize": "1100px" },
    "color": {
      "palette": [
        { "slug": "bg", "color": "#0a0a0a", "name": "Background" },
        { "slug": "surface", "color": "#121212", "name": "Surface" },
        { "slug": "ink", "color": "#f5f5f5", "name": "Ink" },
        { "slug": "soft", "color": "#c2c2c2", "name": "Soft ink" },
        { "slug": "faint", "color": "#8a8a8a", "name": "Faint" },
        { "slug": "line", "color": "#3a3a3a", "name": "Line" },
        { "slug": "accent", "color": "#00e5a0", "name": "Accent" }
      ],
      "custom": false,
      "customGradient": false
    },
    "typography": {
      "customFontSize": false,
      "fontFamilies": [
        {
          "fontFamily": "\"Helvetica Neue\", \"Arial Black\", \"Arial Narrow Bold\", Impact, Haettenschweiler, system-ui, sans-serif",
          "slug": "display",
          "name": "Display"
        },
        {
          "fontFamily": "ui-monospace, \"SFMono-Regular\", \"SF Mono\", Menlo, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
          "slug": "mono",
          "name": "Mono"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.8rem", "name": "Small" },
        { "slug": "medium", "size": "1rem", "name": "Medium" },
        { "slug": "large", "size": "1.6rem", "name": "Large" },
        { "slug": "x-large", "size": "2.6rem", "name": "Extra large" },
        { "slug": "huge", "size": "4.5rem", "name": "Huge" }
      ]
    },
    "spacing": {
      "units": [ "px", "rem", "em", "%", "vw" ]
    }
  },
  "styles": {
    "color": { "background": "#0a0a0a", "text": "#f5f5f5" },
    "typography": { "fontFamily": "ui-monospace, \"SFMono-Regular\", \"SF Mono\", Menlo, Consolas, \"Liberation Mono\", \"Courier New\", monospace" },
    "elements": {
      "link": {
        "color": { "text": "#00e5a0" },
        ":hover": { "color": { "text": "#5cffce" } }
      },
      "h1": { "typography": { "fontFamily": "\"Helvetica Neue\", \"Arial Black\", Impact, system-ui, sans-serif", "textTransform": "uppercase", "letterSpacing": "-0.02em" } },
      "h2": { "typography": { "fontFamily": "\"Helvetica Neue\", \"Arial Black\", Impact, system-ui, sans-serif", "textTransform": "uppercase", "letterSpacing": "-0.02em" } },
      "h3": { "typography": { "fontFamily": "\"Helvetica Neue\", \"Arial Black\", Impact, system-ui, sans-serif", "textTransform": "uppercase", "letterSpacing": "-0.02em" } }
    }
  }
}
