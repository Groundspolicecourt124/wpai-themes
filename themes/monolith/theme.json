{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "layout": { "contentSize": "704px", "wideSize": "1100px" },
    "color": {
      "palette": [
        { "slug": "bg", "color": "#0a0a0a", "name": "Background" },
        { "slug": "surface", "color": "#111111", "name": "Surface" },
        { "slug": "ink", "color": "#f5f5f5", "name": "Ink" },
        { "slug": "soft", "color": "#b3b3b3", "name": "Soft" },
        { "slug": "line", "color": "#2a2a2a", "name": "Line" },
        { "slug": "accent", "color": "#00e5a0", "name": "Accent" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"Archivo Black\", \"Arial Black\", Impact, system-ui, sans-serif",
          "slug": "display",
          "name": "Display"
        },
        {
          "fontFamily": "ui-monospace, \"SFMono-Regular\", Menlo, Consolas, monospace",
          "slug": "mono",
          "name": "Mono"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.8rem", "name": "Small" },
        { "slug": "medium", "size": "1rem", "name": "Medium" },
        { "slug": "large", "size": "1.6rem", "name": "Large" },
        { "slug": "x-large", "size": "2.6rem", "name": "Extra large" },
        { "slug": "huge", "size": "4rem", "name": "Huge" }
      ]
    }
  },
  "styles": {
    "color": { "background": "#0a0a0a", "text": "#f5f5f5" },
    "elements": {
      "link": { "color": { "text": "#00e5a0" } }
    }
  }
}
