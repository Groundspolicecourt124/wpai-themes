{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "layout": { "contentSize": "704px", "wideSize": "1024px" },
    "color": {
      "palette": [
        { "slug": "ink", "color": "#181b27", "name": "Ink" },
        { "slug": "soft", "color": "#4a5168", "name": "Soft" },
        { "slug": "accent", "color": "#6366f1", "name": "Indigo" },
        { "slug": "violet", "color": "#8b5cf6", "name": "Violet" },
        { "slug": "accent-deep", "color": "#4f46e5", "name": "Deep Indigo" },
        { "slug": "canvas", "color": "#f6f7fb", "name": "Canvas" },
        { "slug": "surface", "color": "#ffffff", "name": "Surface" }
      ],
      "gradients": [
        {
          "slug": "violet-indigo",
          "gradient": "linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)",
          "name": "Violet to Indigo"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
          "slug": "sans",
          "name": "Sans"
        },
        {
          "fontFamily": "ui-monospace, \"SF Mono\", \"Cascadia Code\", \"JetBrains Mono\", Menlo, Consolas, monospace",
          "slug": "mono",
          "name": "Mono"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1.0625rem", "name": "Medium" },
        { "slug": "large", "size": "1.25rem", "name": "Large" },
        { "slug": "x-large", "size": "2rem", "name": "Extra large" },
        { "slug": "xx-large", "size": "3rem", "name": "Huge" }
      ]
    }
  },
  "styles": {
    "color": { "background": "#f6f7fb", "text": "#181b27" },
    "typography": {
      "fontFamily": "ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
      "lineHeight": "1.7"
    },
    "elements": {
      "link": { "color": { "text": "#3f37c9" } },
      "h1": { "typography": { "fontWeight": "800", "letterSpacing": "-0.022em" } },
      "h2": { "typography": { "fontWeight": "800", "letterSpacing": "-0.022em" } }
    }
  }
}
