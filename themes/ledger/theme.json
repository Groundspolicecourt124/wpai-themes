{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": { "contentSize": "640px", "wideSize": "1024px" },
    "color": {
      "palette": [
        { "slug": "ink", "color": "#16130f", "name": "Ink" },
        { "slug": "soft", "color": "#463f37", "name": "Soft" },
        { "slug": "accent", "color": "#a4001a", "name": "Accent" },
        { "slug": "accent-ink", "color": "#7d0014", "name": "Accent ink" },
        { "slug": "paper", "color": "#faf8f4", "name": "Paper" },
        { "slug": "surface", "color": "#fffdf9", "name": "Surface" },
        { "slug": "line", "color": "#ddd5c7", "name": "Rule" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Charter, \"Iowan Old Style\", \"Palatino Linotype\", Palatino, Georgia, \"Times New Roman\", serif",
          "slug": "serif",
          "name": "Serif"
        },
        {
          "fontFamily": "\"Helvetica Neue\", Helvetica, Arial, system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif",
          "slug": "sans",
          "name": "Sans"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.85rem", "name": "Small" },
        { "slug": "medium", "size": "1.06rem", "name": "Medium" },
        { "slug": "large", "size": "1.42rem", "name": "Large" },
        { "slug": "x-large", "size": "2.5rem", "name": "Extra large" }
      ]
    }
  },
  "styles": {
    "color": { "background": "#faf8f4", "text": "#16130f" },
    "typography": { "fontFamily": "Charter, \"Iowan Old Style\", \"Palatino Linotype\", Palatino, Georgia, \"Times New Roman\", serif" },
    "elements": {
      "link": {
        "color": { "text": "#a4001a" },
        ":hover": { "color": { "text": "#7d0014" } }
      },
      "h2": { "typography": { "fontFamily": "Charter, \"Iowan Old Style\", \"Palatino Linotype\", Palatino, Georgia, \"Times New Roman\", serif" } }
    }
  }
}
